PYTHONDONTWRITEBYTECODE=1
FLASK_ENV="development" # FLASK_ENV=production for production environment
SECRET_KEY="your-secret-key"
MONGO_URI="mongodb+srv://<username>:<password>@<host>/<databasename>?authSource=admin&retryWrites=true&w=majority"
S3_BUCKET_URI="https://public-bucket-for-general-purpose-storage-12-02-2026.s3.ap-south-1.amazonaws.com/project-flask-moviedb/"
S3_BUCKET_NAME="public-bucket-for-general-purpose-storage-12-02-2026"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_DEFAULT_REGION="us-east-1"